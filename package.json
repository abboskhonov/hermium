{
  "name": "hermium",
  "private": true,
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "AUTH_DISABLED=1 turbo run dev --filter=@hermium/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=@hermium/api",
    "build:shared": "turbo run build --filter=@hermium/shared",
    "build:cli": "turbo run build --filter=hermium",
    "start": "turbo run start --filter=@hermium/api",
    "cli:start": "turbo run start --filter=hermium",
    "cli:build": "turbo run build --filter=hermium",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf .turbo"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3"
  }
}
