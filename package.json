{
  "name": "hermium",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:api\"",
    "dev:web": "bun --cwd packages/web dev",
    "dev:api": "AUTH_DISABLED=1 bun --cwd packages/api dev",
    "build": "bun run build:shared && bun run build:api && bun run build:web",
    "build:web": "bun --cwd packages/web build",
    "build:api": "bun --cwd packages/api build",
    "build:shared": "bun --cwd packages/shared build",
    "start": "bun --cwd packages/api start",
    "lint": "bun --cwd packages/web lint && bun --cwd packages/api lint",
    "typecheck": "bun --cwd packages/web typecheck && bun --cwd packages/api typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.9.3"
  }
}
