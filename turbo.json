{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "AUTH_DISABLED", "HERMES_HOME", "WEB_STATIC_DIR", "PORT"],
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
